{
  "name": "@thisdot/visual-regression",
  "version": "1.0.0",
  "description": "Shared visual regression toolkit: configuration, Next.js prerender route discovery, deterministic Chromium capture, artifact-backed baselines, comparison, and reporting.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrandonMathis/visual-regression-toolkit.git"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "visual-regression": "./dist/cli/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "@playwright/test": "1.61.1",
    "ajv": "8.20.0",
    "commander": "15.0.0",
    "jiti": "2.7.0",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
