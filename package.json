{
  "name": "@thisdot/visual-regression",
  "version": "0.0.0",
  "private": true,
  "description": "Deterministic visual regression toolkit for Next.js applications",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrandonMathis/visual-regression-toolkit.git"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/config": "./schemas/config.schema.json",
    "./schemas/baseline-manifest": "./schemas/baseline-manifest.schema.json",
    "./schemas/visual-result": "./schemas/visual-result.schema.json"
  },
  "bin": {
    "visual-regression": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "SECURITY.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "check:schemas": "tsx scripts/check-schema-drift.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "check:package": "tsx scripts/check-package.ts",
    "check:workflows": "node scripts/check-workflows.mjs"
  },
  "dependencies": {
    "@playwright/test": "1.61.1",
    "ajv": "8.20.0",
    "css-tree": "3.1.0",
    "css-what": "8.0.0",
    "jiti": "2.6.1",
    "picomatch": "4.0.5",
    "pixelmatch": "7.1.0",
    "pngjs": "7.0.0",
    "yauzl": "3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/css-tree": "2.3.11",
    "@types/node": "22.19.11",
    "@types/picomatch": "4.0.2",
    "@types/pngjs": "6.0.5",
    "@types/yauzl": "3.4.0",
    "@types/yazl": "3.3.1",
    "eslint": "9.39.2",
    "prettier": "3.8.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "4.1.10",
    "yazl": "3.3.1"
  }
}
