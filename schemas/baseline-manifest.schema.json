{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/thisdot/visual-regression-toolkit/schemas/baseline-manifest.schema.json",
  "title": "BaselineManifest",
  "description": "Verified baseline artifact manifest (plan section 8.1). schemaVersion const mirrors BASELINE_MANIFEST_SCHEMA_VERSION in src/runtime.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "baseBranch",
    "sourceSha",
    "workflowRunId",
    "workflowRunAttempt",
    "createdAt",
    "logicalDate",
    "toolkit",
    "playwrightVersion",
    "chromiumRevision",
    "environment",
    "visualContractHash",
    "adapter",
    "projects",
    "routes",
    "screenshots"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "repository": { "type": "string", "minLength": 1, "maxLength": 500 },
    "baseBranch": { "type": "string", "minLength": 1, "maxLength": 500 },
    "sourceSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "workflowRunId": { "type": "string", "minLength": 1, "maxLength": 500 },
    "workflowRunAttempt": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "minLength": 1, "maxLength": 500 },
    "logicalDate": { "type": "string", "minLength": 1, "maxLength": 500 },
    "toolkit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 500 },
        "version": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "playwrightVersion": { "type": "string", "minLength": 1, "maxLength": 500 },
    "chromiumRevision": { "type": "string", "minLength": 1, "maxLength": 500 },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "containerDigest", "platform"],
      "properties": {
        "os": { "type": "string", "minLength": 1, "maxLength": 500 },
        "arch": { "type": "string", "minLength": 1, "maxLength": 500 },
        "containerDigest": { "type": "string", "minLength": 1, "maxLength": 500 },
        "platform": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "visualContractHash": { "type": "string", "minLength": 1, "maxLength": 500 },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "behaviorVersion"],
      "properties": {
        "type": { "const": "next-prerender" },
        "behaviorVersion": { "type": "integer", "minimum": 1 }
      }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "width", "height", "deviceScaleFactor", "hasTouch", "isMobile"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 500 },
          "width": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "height": { "type": "integer", "minimum": 1, "maximum": 100000 },
          "deviceScaleFactor": { "type": "number", "exclusiveMinimum": 0, "maximum": 10 },
          "hasTouch": { "type": "boolean" },
          "isMobile": { "type": "boolean" }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route", "screenshotName"],
        "properties": {
          "route": { "type": "string", "pattern": "^/", "maxLength": 500 },
          "screenshotName": {
            "type": "string",
            "pattern": "^(?!.*\\.\\.)[^/\\\\]+$",
            "maxLength": 500
          }
        }
      }
    },
    "screenshots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project", "route", "path", "width", "height", "bytes", "sha256"],
        "properties": {
          "project": { "type": "string", "minLength": 1, "maxLength": 500 },
          "route": { "type": "string", "pattern": "^/", "maxLength": 500 },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*\\.\\.)[^\\\\]+$",
            "maxLength": 500
          },
          "width": { "type": "integer", "minimum": 1, "maximum": 1000000 },
          "height": { "type": "integer", "minimum": 1, "maximum": 1000000 },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
